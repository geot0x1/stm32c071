CompileFlags:
  CompilationDatabase: build/Debug

---

# Suppress all diagnostics in vendor/generated STM32 HAL and CMSIS files.
# These headers have circular includes (stm32c0xx_hal_def.h → stm32c0xx.h →
# stm32c0xx_hal.h → ...) that GCC handles via the normal .c file entry point
# but cause false positives when clangd analyses headers standalone.
If:
  PathMatch: [Drivers/.*, cmake/stm32cubemx/.*]
Diagnostics:
  Suppress: '*'
